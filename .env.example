# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is safe to commit (no secrets).

# Anthropic API key — used for generation (summaries, extraction, answers).
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Voyage AI API key — used for embeddings (RAG).
# Anthropic has no embeddings endpoint; Voyage is their recommended provider.
# Generous free token allowance. https://dashboard.voyageai.com/
VOYAGE_API_KEY=
