# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this .env.example is safe to commit (no secrets).

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI API key — used for embeddings in the RAG phase
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
